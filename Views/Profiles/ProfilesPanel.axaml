<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:league_mh_viewer.ViewModels"
             xmlns:profiles="using:league_mh_viewer.Views.Profiles"
             x:Class="league_mh_viewer.Views.Profiles.ProfilesPanel"
             x:DataType="vm:ProfilesPanelViewModel">

  <Border Background="{StaticResource BrushSurface}"
          CornerRadius="16"
          Padding="16">

    <Grid RowDefinitions="Auto,Auto,*">
      <TextBlock Text="Profiles"
                 Classes="section" />

      <StackPanel Grid.Row="1"
                  Spacing="8"
                  Margin="0 0 0 16">

        <TextBox PlaceholderText="Riot name"
                 Text="{Binding Name, Mode=TwoWay}" />

        <TextBox PlaceholderText="Tag"
                 Text="{Binding Tag, Mode=TwoWay}" />

        <Button Content="Add profile"
                Classes="primary"
                Command="{Binding AddProfileCommand}" />
      </StackPanel>

      <ScrollViewer Grid.Row="2"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">

        <ItemsControl ItemsSource="{Binding Profiles}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="8" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>

          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <profiles:ProfileCard />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
