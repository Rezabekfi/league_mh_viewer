<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:league_mh_viewer.ViewModels.Items"
             x:Class="league_mh_viewer.Views.Profiles.ProfileCard"
             x:DataType="vm:LeagueProfileDisplayItem">

  <Border Classes="card">
    <StackPanel>
      <TextBlock Text="{Binding Profile.Name}"
                 FontWeight="SemiBold"
                 FontSize="15" />

      <TextBlock Text="{Binding Profile.Rank}"
                 Classes="muted" />
    </StackPanel>
  </Border>
</UserControl>
