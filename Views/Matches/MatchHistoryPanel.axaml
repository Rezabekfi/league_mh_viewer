<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:league_mh_viewer.ViewModels"
             xmlns:items="using:league_mh_viewer.ViewModels.Items"
             xmlns:matches="using:league_mh_viewer.Views.Matches"
             x:Class="league_mh_viewer.Views.Matches.MatchHistoryPanel"
             x:DataType="vm:MatchHistoryPanelViewModel">

  <Border Background="{StaticResource BrushSurface}" CornerRadius="16" Padding="16">
    <Grid RowDefinitions="Auto,*">
      <Grid ColumnDefinitions="*,Auto" Margin="0 0 0 16">
        <StackPanel>
          <TextBlock Text="Match history" Classes="title" />
          <TextBlock Text="Recent games for the selected profile"
                     Classes="muted" />
        </StackPanel>
      </Grid>

<ScrollViewer Grid.Row="1"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">

      <ItemsControl 
         ItemsSource="{Binding Matches}">

<ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Spacing="8"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
  <ItemsControl.ItemTemplate>
    <DataTemplate x:DataType="vm:MatchCardViewModel">
      <matches:MatchCard />
    </DataTemplate>
  </ItemsControl.ItemTemplate>

</ItemsControl>
</ScrollViewer>
</Grid>
  </Border>
</UserControl>
