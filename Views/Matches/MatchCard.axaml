<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:league_mh_viewer.ViewModels"
             x:Class="league_mh_viewer.Views.Matches.MatchCard"
             x:DataType="vm:MatchCardViewModel">

  <Border Classes="card"
          Classes.win="{Binding Match.Win}"
          Classes.loss="{Binding !Match.Win}">

    <StackPanel>
      <Grid ColumnDefinitions="50,*,*,*,*,Auto,Auto">
        <Border Grid.Column="0" Width="48" CornerRadius="24" ClipToBounds="True">
          <Image Source="{Binding Match.PlayerStats.ChampionIcon}"/>
        </Border>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center" 
                    Margin="12 0">

          <TextBlock Text="{Binding Result}"
                     Classes="result" />

          <TextBlock Text="{Binding Match.PlayerStats.ChampionName}"
                     Classes="champion"
                     />
        </StackPanel>

        <StackPanel Grid.Column="2" VerticalAlignment="Center" >
          <TextBlock Text="{Binding Match.PlayerStats.Name}"
          ToolTip.Tip="{Binding Match.PlayerStats.SummonerName}" />
          <TextBlock Text="{Binding Match.DateTime, StringFormat='{}{0:dd.MM HH:mm}'}" />
        </StackPanel>

        <StackPanel Grid.Column="3" VerticalAlignment="Center">
          <TextBlock Text="{Binding DurationText}" VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Grid.Column="4"
                    Orientation="Horizontal" VerticalAlignment="Center">

          <TextBlock Text="Score" />
          <TextBlock Text="{Binding Match.PlayerStats.ScoreText}" />
        </StackPanel>

        <StackPanel Grid.Column="5"
                    Margin="12 0" VerticalAlignment="Center">

          <TextBlock Text="CS" />
          <TextBlock Text="{Binding Match.PlayerStats.CS}" />
        </StackPanel>

        <Button Grid.Column="6"
                Classes="primary"
                Command="{Binding ToggleExpandedCommand}">

          <PathIcon Data="{Binding ExpandIcon}"
                    Width="16"
                    Height="16" />
        </Button>
      </Grid>

      <Grid IsVisible="{Binding IsExpanded}"
      Margin="12 12 12 0"
      ColumnDefinitions="*,24,*">

  <!-- Left team -->
  <ItemsControl Grid.Column="0"
                ItemsSource="{Binding AllyPlayers}">
    <ItemsControl.ItemTemplate>
      <DataTemplate>
        <Grid ColumnDefinitions="32,*,120,60,70"
              Margin="0 4">

          <!-- Champion icon -->
          <Image Grid.Column="0"
                 Width="28"
                 Height="28"
                 VerticalAlignment="Center"
                 Source="{Binding ChampionIcon}" />

          <!-- Champion name -->
          <TextBlock Grid.Column="1"
                     Margin="8 0"
                     VerticalAlignment="Center"
                     Text="{Binding ChampionName}" />

          <!-- Player name -->
          <TextBlock Grid.Column="2"
                     Margin="8 0"
                     VerticalAlignment="Center"
                     Text="{Binding Name}"
                     ToolTip.Tip="{Binding SummonerName}"
                     TextTrimming="CharacterEllipsis" />

          <!-- CS -->
          <TextBlock Grid.Column="3"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Text="{Binding CS, StringFormat='CS {0}'}" />

          <!-- Score -->
          <TextBlock Grid.Column="4"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Right"
                     Text="{Binding ScoreText}" />
        </Grid>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>

  <!-- Divider -->
  <Border Grid.Column="1"
          Width="1"
          HorizontalAlignment="Center"
          Background="{DynamicResource ThemeBorderLowBrush}" />

  <!-- Right team -->
  <ItemsControl Grid.Column="2"
                ItemsSource="{Binding EnemyPlayers}">
    <ItemsControl.ItemTemplate>
      <DataTemplate>
        <Grid ColumnDefinitions="32,*,120,60,70"
              Margin="0 4">

          <Image Grid.Column="0"
                 Width="28"
                 Height="28"
                 VerticalAlignment="Center"
                 Source="{Binding ChampionIcon}" />

          <TextBlock Grid.Column="1"
                     Margin="8 0"
                     VerticalAlignment="Center"
                     Text="{Binding ChampionName}" />

          <TextBlock Grid.Column="2"
                     Margin="8 0"
                     VerticalAlignment="Center"
                     Text="{Binding Name}"
                     ToolTip.Tip="{Binding SummonerName}"
                     TextTrimming="CharacterEllipsis" />

          <TextBlock Grid.Column="3"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"
                     Text="{Binding CS, StringFormat='CS {0}'}" />

          <TextBlock Grid.Column="4"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Right"
                     Text="{Binding ScoreText}" />
        </Grid>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>

</Grid>    </StackPanel>
  </Border>
</UserControl>
