<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:items="using:league_mh_viewer.Models"
             x:Class="league_mh_viewer.Views.Matches.MatchCard"
             x:DataType="items:MatchItem">

  <Border 
  Classes="card"
  Classes.win="{Binding Win}"
  Classes.loss="{Binding !Win}"
  >
    <Grid ColumnDefinitions="*,*,*,Auto">

      <Border Width="6"
              CornerRadius="3"/>


      <StackPanel Grid.Column="0"
                  Margin="12 0">

        <TextBlock Text="{Binding Result}" Classes="result"/>

        <TextBlock Text="{Binding PlayerStats.ChampionName}"
                   Classes="champion" />

      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal">

        <TextBlock Text="Score" />
        <TextBlock Text="{Binding PlayerStats.ScoreText}" />
      
      </StackPanel>

      <StackPanel Grid.Column="2" Margin="12 0">

      <TextBlock Text="CS"/>
      <TextBlock Text="{Binding PlayerStats.CS}"/>
      
      </StackPanel>
      <Button Grid.Column="3" Classes="primary" >
        <PathIcon Data="{StaticResource arrow_sync_circle_regular}" Width="16" Height="16" />
      </Button>

    </Grid>
  </Border>
</UserControl>
