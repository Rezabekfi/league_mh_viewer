<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:league_mh_viewer.ViewModels"
             x:Class="league_mh_viewer.Views.Matches.MatchCard"
             x:DataType="vm:MatchCardViewModel">

  <Border Classes="card"
          Classes.win="{Binding Match.Win}"
          Classes.loss="{Binding !Match.Win}">

    <StackPanel>
      <Grid ColumnDefinitions="50,*,*,*,*,Auto,Auto">
        <Image Grid.Column="0" Source="{Binding Match.PlayerStats.ChampionIcon}"/>

        <StackPanel Grid.Column="1"
                    Margin="12 0">

          <TextBlock Text="{Binding Result}"
                     Classes="result" />

          <TextBlock Text="{Binding Match.PlayerStats.ChampionName}"
                     Classes="champion" />
        </StackPanel>

        <StackPanel Grid.Column="2">
          <TextBlock Text="{Binding Match.PlayerStats.SummonerName}" />
          <TextBlock Text="{Binding Match.DateTime, StringFormat='{}{0:dd.MM HH:mm}'}" />
        </StackPanel>

        <StackPanel Grid.Column="3">
          <TextBlock Text="{Binding DurationText}" />
        </StackPanel>
        <StackPanel Grid.Column="4"
                    Orientation="Horizontal">

          <TextBlock Text="Score" />
          <TextBlock Text="{Binding Match.PlayerStats.ScoreText}" />
        </StackPanel>

        <StackPanel Grid.Column="5"
                    Margin="12 0">

          <TextBlock Text="CS" />
          <TextBlock Text="{Binding Match.PlayerStats.CS}" />
        </StackPanel>

        <Button Grid.Column="6"
                Classes="primary"
                Command="{Binding ToggleExpandedCommand}">

          <PathIcon Data="{Binding ExpandIcon}"
                    Width="16"
                    Height="16" />
        </Button>
      </Grid>

      <Grid ColumnDefinitions="*,*,*,*"
            IsVisible="{Binding IsExpanded}"
            Margin="12 12 12 0">

        <TextBlock Grid.Column="0"
                   Text="YO" />

        <TextBlock Grid.Column="1"
                   Text="YO" />

        <TextBlock Grid.Column="2"
                   Text="YO" />

        <TextBlock Grid.Column="3"
                   Text="YO" />
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
