<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:league_mh_viewer.ViewModels"
        xmlns:profiles="using:league_mh_viewer.Views.Profiles"
        xmlns:matches="using:league_mh_viewer.Views.Matches"
        x:Class="league_mh_viewer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1000"
        Height="650"
        MinWidth="850"
        MinHeight="520"
        Title="League Match History">

  <Grid Background="{StaticResource BrushBackground}" RowDefinitions="Auto,*">
    <Border Grid.Row="0" Background="{StaticResource BrushSurface}" Padding="20 14">
      <TextBlock Text="League Match History" Classes="title" />
    </Border>

    <Grid Grid.Row="1"
          ColumnDefinitions="250,*"
          Margin="20"
          ColumnSpacing="20">

      <profiles:ProfilesPanel DataContext="{Binding ProfilesPanel}" />

      <matches:MatchHistoryPanel Grid.Column="1"
                                 DataContext="{Binding MatchHistory}" />
    </Grid>
  </Grid>
</Window>
