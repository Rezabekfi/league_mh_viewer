<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="league_mh_viewer.App"
             xmlns:local="using:league_mh_viewer"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://league_mh_viewer/Styles/Colors.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://league_mh_viewer/Styles/Text.axaml" />
        <StyleInclude Source="avares://league_mh_viewer/Styles/Controls.axaml" />
    </Application.Styles>
</Application>
